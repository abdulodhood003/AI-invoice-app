{
  "version": 2,
  "builds": [
    {
      "src": "server/server.js",
      "use": "@vercel/node"
    },
    {
      "src": "client/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    }
  ],
  "rewrites": [
    {
      "source": "/api/:match*",
      "destination": "/server/server.js"
    },
    {
      "source": "/assets/:match*",
      "destination": "/client/dist/assets/:match*"
    },
    {
      "source": "/:match*",
      "destination": "/client/dist/index.html"
    }
  ]
}
